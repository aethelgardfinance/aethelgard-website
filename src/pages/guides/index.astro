---
import '../../styles/global.css';

const guides = [
  {
    href: '/guides/financial-reports',
    title: "Reading Aethelgard's P&L and Balance Sheet",
    description: 'Use the two core financial statements as decision tools rather than compliance artefacts. What to look for, how to drill in.',
    tag: 'Reporting',
  },
  {
    href: '/guides/multi-entity-consolidation',
    title: 'Multi-entity consolidation',
    description: 'Model an operating company, a holding company, a personal account, and a trust as one group — with both standalone and consolidated reports.',
    tag: 'Multi-entity',
  },
  {
    href: '/guides/trust-and-holding-company-setup',
    title: 'Setting up trusts and holding companies',
    description: 'Use entity classes and inter-company tools to model trusts, holding companies, and their internal loans with the audit trail required to protect the structure.',
    tag: 'Structure',
  },
  {
    href: '/guides/recurring-transactions',
    title: 'Recurring transactions',
    description: 'Define repeated entries once and have Aethelgard either post them automatically or remind you to confirm them.',
    tag: 'Operations',
  },
  {
    href: '/guides/period-close',
    title: 'Month-end and year-end close',
    description: 'The discipline that turns a ledger into a defensible record — reconcile, balance, lock, and post the year-end close so what your accountant inherits is auditable.',
    tag: 'Operations',
  },
  {
    href: '/guides/webdav-backup',
    title: 'WebDAV backup',
    description: "How Aethelgard's encrypted off-site backup works, and how to set it up against your own infrastructure.",
    tag: 'Security',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Guides — Aethelgard</title>
    <meta name="description" content="In-depth guides on using Aethelgard for multi-entity wealth, consolidation, recurring transactions, trust and holding-company setup, and encrypted backup." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-navy-900 border-b border-white/5">
      <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-white font-black tracking-tight text-lg uppercase italic">Aethelgard</a>
        <div class="flex items-center gap-6">
          <a href="/guides" class="text-sm font-semibold text-white">Guides</a>
          <a href="/#pricing" class="text-sm font-semibold text-white/50 hover:text-white transition-colors hidden sm:block">Pricing</a>
          <a href="/#early-access" class="text-sm font-semibold text-brand-400 hover:text-brand-300 transition-colors hidden sm:block">Design Partners</a>
        </div>
      </div>
    </nav>

    <!-- Header -->
    <header class="bg-navy-900 py-20 px-6 border-b border-white/5">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-2 text-white/30 text-xs font-bold uppercase tracking-widest mb-4">
          <a href="/" class="hover:text-white/60 transition-colors">Home</a>
          <span>/</span>
          <span class="text-white/60">Guides</span>
        </div>
        <p class="section-label mb-3">Documentation</p>
        <h1 class="text-5xl font-black tracking-tighter text-white mb-4">Guides</h1>
        <p class="text-white/60 text-lg max-w-2xl">
          Practical walkthroughs for the parts of Aethelgard that reward a few minutes of context — multi-entity consolidation, trust and holding-company setup, the reporting engine, and encrypted off-site backup.
        </p>
      </div>
    </header>

    <!-- Guide list -->
    <main class="bg-white py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <ul class="space-y-4">
          {guides.map(g => (
            <li>
              <a href={g.href} class="block group rounded-2xl border border-neutral-200 hover:border-brand-400 hover:shadow-lg hover:shadow-brand-500/5 p-6 transition-all">
                <div class="flex items-start justify-between gap-4 mb-2">
                  <h2 class="text-xl font-black tracking-tight text-neutral-900 group-hover:text-brand-700 transition-colors">{g.title}</h2>
                  <span class="shrink-0 text-[10px] font-black uppercase tracking-widest text-brand-600 bg-brand-50 px-2.5 py-1 rounded-full">{g.tag}</span>
                </div>
                <p class="text-neutral-600 text-sm leading-relaxed">{g.description}</p>
                <p class="mt-3 text-sm font-bold text-brand-600 group-hover:text-brand-700 transition-colors">Read guide →</p>
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-12 pt-8 border-t border-neutral-200 text-center">
          <p class="text-neutral-500 text-sm mb-4">Looking for setup steps rather than concepts?</p>
          <a href="/quick-start" class="inline-flex items-center gap-2 px-6 py-3 border border-neutral-300 text-neutral-700 font-semibold rounded-xl hover:border-neutral-900 hover:text-neutral-900 transition-colors">
            Quick Start guide
          </a>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="bg-navy-900 text-white/40 text-sm py-8 px-6 border-t border-white/5">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <p>© 2026 Aethelgard. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a href="/privacy" class="hover:text-white/70 transition-colors">Privacy</a>
          <a href="/terms" class="hover:text-white/70 transition-colors">Terms</a>
          <a href="/refunds" class="hover:text-white/70 transition-colors">Refunds</a>
        </div>
      </div>
    </footer>
  </body>
</html>
