---
import '../styles/global.css';

// Paddle price IDs — one per tier × billing period.
const PRICES = {
  basic_annual:     'pri_01kp3v73e48jfzv934q04x9dzr',
  standard_annual:  'pri_01kp3vagrpers8t1h2n5ea0kfm',
  advanced_annual:  'pri_01kp3vdkfgxfvxym73vvkpkw05',
  basic_lifetime:   'pri_01kp3vz3h9nnyg5erqm01m3tsg',
  standard_lifetime:'pri_01kp3w7wk0t5bd9dgyhky2cea4',
  advanced_lifetime:'pri_01kp3wa2e1ym23f039fjhg0m72',
  advisor_bundle:   'pri_01kprs255tq3nfemq9h5zn3ejt',
};

// GitHub releases — update to point at latest release once published.
const DOWNLOAD_WIN = 'https://github.com/aethelgardfinance/aethelgard-releases/releases';
const DOWNLOAD_MAC = null; // Set once Mac build is ready

// Demo video — set to your Loom or YouTube embed URL once recorded.
// Loom:    https://www.loom.com/embed/YOUR_VIDEO_ID?hide_owner=true&hide_share=true&hide_title=true&hideEmbedTopBar=true
// YouTube: https://www.youtube.com/embed/YOUR_VIDEO_ID
const DEMO_VIDEO_URL = null;

const features = [
  {
    icon: '🗺',
    title: 'The Family Succession Map',
    body: 'Give your family absolute clarity. Aethelgard creates a definitive, secure record of "what we own, where it is, and how much it\'s worth" — so your trusted successors have the exact information they need, right when they need it.',
  },
  {
    icon: '🏛',
    title: 'Track Everything You Own',
    body: 'Go beyond traditional bank accounts. Track your global real estate, private equity, digital assets, and physical wealth — the assets standard software ignores — all in one complete picture.',
  },
  {
    icon: '🔗',
    title: 'The Complete Wealth Ledger',
    body: 'Consolidate your entire financial footprint. Manage funds across multiple companies, personal accounts, charitable foundations, and distinct cost centres — all without friction or fragmentation.',
  },
  {
    icon: '🔒',
    title: 'Local-First Privacy',
    body: 'Your financial map is no one else\'s business. Aethelgard runs purely on your own device with zero telemetry or cloud requirements. Your data is locked behind AES-256 encryption and remains solely under your control.',
  },
];

const comparison = [
  { feature: 'Core Focus',       aethelgard: 'HNW Sovereign Wealth & Legacy', spreadsheet: 'Basic tracking', saas: 'SME Business Accounting', institutional: 'Institutional Management' },
  { feature: 'Asset Breadth',    aethelgard: 'Unrestricted — Property, Crypto, LLCs', spreadsheet: 'Highly manual', saas: 'Bank accounts & fiat only', institutional: 'High-friction setup' },
  { feature: 'Family Clarity',   aethelgard: 'Unified "What, Where, How Much"', spreadsheet: 'Fragmented', saas: 'None', institutional: 'Complex reporting' },
  { feature: 'Privacy Model',    aethelgard: 'Purely local — fully on your device', spreadsheet: 'Cloud or local', saas: '100% cloud / SaaS', institutional: '100% cloud / SaaS' },
  { feature: 'Pricing',          aethelgard: 'Annual from £99 · Lifetime from £249', spreadsheet: 'Ongoing subscriptions', saas: 'Ongoing subscriptions', institutional: 'Enterprise fees' },
];

const faqs = [
  {
    q: 'What is the Windows SmartScreen warning?',
    a: 'When you first install Aethelgard on Windows, you may see a warning from Windows SmartScreen saying "Windows protected your PC." This is a standard notice for new independent software — it does not mean anything is wrong. Click More info, then Run anyway to proceed. The warning fades as Aethelgard builds reputation with Microsoft over time.',
  },
  {
    q: 'How private is my data?',
    a: 'Extremely private. Aethelgard is a local-first application — there are no mandatory cloud accounts, no telemetry, and no background sync unless you configure it. Your financial history lives only on your machine, protected by AES-256 encryption.',
  },
  {
    q: 'Where is my information stored?',
    a: 'Your ledger is kept securely on your personal device. For peace of mind you can create encrypted backup vaults that sync to your own private cloud storage — you remain completely in control of where your backups go.',
  },
  {
    q: 'What is the difference between Annual and Lifetime?',
    a: 'Annual access gives you the full product for 12 months and renews each year. A Lifetime license is a one-time purchase — you own it permanently with no further payments. Both options include the same features. You can upgrade from Annual to Lifetime at any time and we\'ll credit the difference.',
  },
  {
    q: 'What is your refund policy?',
    a: 'We encourage you to download and try free for 30 days before buying — no card required. That way you know exactly what you\'re getting before any money changes hands. If you\'ve already purchased and something isn\'t working for you, contact us directly and we\'ll make it right.',
  },
  {
    q: 'Does Aethelgard work on Mac?',
    a: 'A Mac version is in active development and will be released soon. Windows users can download the current release today. Join the mailing list to be notified the moment the Mac build is available.',
  },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="One complete picture of your wealth — companies, property, investments, and assets — private on your own device." />
  <title>Aethelgard — Private Wealth Ledger</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Open Graph -->
  <meta property="og:title" content="Aethelgard — Private Wealth Ledger" />
  <meta property="og:description" content="One complete picture of your wealth — private on your own device." />
  <meta property="og:url" content="https://aethelgard.finance" />
  <meta property="og:type" content="website" />
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <!-- Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Aethelgard",
      "operatingSystem": "Windows, macOS",
      "applicationCategory": "FinanceApplication",
      "offers": {
        "@type": "Offer",
        "price": "99.00",
        "priceCurrency": "USD"
      },
      "featureList": "Double-entry accounting, multi-entity support, private wealth management, local-first encryption",
      "author": {
        "@type": "Organization",
        "name": "Aethelgard"
      }
    }
  </script>
</head>

<body class="bg-white text-neutral-900 antialiased">

  <!-- â"€â"€ Navigation â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
  <nav class="fixed top-0 inset-x-0 z-50 bg-navy-900/95 backdrop-blur-sm border-b border-white/5">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/favicon.svg" alt="Aethelgard" class="h-7 w-7 rounded-lg shadow-lg" />
        <span class="font-black text-white tracking-tighter uppercase italic text-lg">Aethelgard</span>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm font-semibold text-white/60">
        <a href="#features"     class="hover:text-white transition-colors">Features</a>
        <a href="#demo"         class="hover:text-white transition-colors">Demo</a>
        <a href="#pricing"      class="hover:text-white transition-colors">Pricing</a>
        <a href="#early-access" class="hover:text-white transition-colors text-brand-400">Early Access</a>
        <a href="/pdf-studio"   class="hover:text-white transition-colors">PDF Studio</a>
        <a href="#faq"          class="hover:text-white transition-colors">FAQ</a>
        <a href="/about"        class="hover:text-white transition-colors">About</a>
      </div>
      <a href={DOWNLOAD_WIN} class="btn-primary text-sm py-2 px-4 js-win-download">
        Download
        <span class="text-white/60 font-normal text-xs">Windows</span>
      </a>
    </div>
  </nav>

  <!-- â"€â"€ Hero â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
  <section class="relative bg-navy-900 pt-32 pb-28 px-6 overflow-hidden">
    <!-- Subtle grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Amber glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-brand-500/10 blur-3xl rounded-full pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-brand-500/10 border border-brand-500/20 rounded-full px-4 py-1.5 text-brand-400 text-xs font-bold uppercase tracking-widest mb-8">
        Windows · Mac coming soon
      </div>

      <h1 class="text-5xl md:text-6xl font-black text-white leading-[1.05] tracking-tighter mb-6">
        One complete picture<br class="hidden md:block" />
        of your wealth.
      </h1>

      <p class="text-xl text-white/60 font-medium leading-relaxed max-w-2xl mx-auto mb-10">
        Private on your own device. Built for complex assets, family continuity, and absolute control.
        No cloud. No telemetry. No account required.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-2">
        <a href={DOWNLOAD_WIN} id="primary-cta" class="btn-primary text-base px-8 py-3.5">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          <span id="cta-text">Start Free Trial — Windows</span>
        </a>
        <div id="mac-waitlist-trigger" class="hidden">
           <a href="#mac-waitlist" class="btn-ghost text-base px-8 py-3.5">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg>
            Mac — Join Waitlist
          </a>
        </div>
      </div>
      <p id="version-tag" class="text-[10px] text-white/20 font-bold mb-8 uppercase tracking-widest opacity-0 transition-opacity">
        Latest Version: <span id="version-number">...</span>
      </p>

      <p class="text-xs text-white/30 font-medium tracking-wide mb-16">
        30-day free trial · No account required · Your data never leaves your device
      </p>

      <!-- Dashboard Mockup -->
      <div class="relative max-w-5xl mx-auto px-4 -mb-48 md:-mb-64">
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-brand-500/20 to-brand-600/20 rounded-2xl blur opacity-75 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative bg-navy-800 border border-white/10 rounded-2xl shadow-2xl overflow-hidden aspect-[16/10]">
             <img loading="lazy" src="/screenshots/wealth-summary.png" alt="Aethelgard — Consolidated Wealth Summary" class="w-full h-full object-cover">
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Spacer for the overlapping hero mockup -->
  <div class="h-48 md:h-64 bg-neutral-50"></div>

  <!-- â"€â"€ Features â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
  <section id="features" class="py-24 px-6 bg-neutral-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="section-label mb-3">Why Aethelgard</p>
        <h2 class="text-4xl font-black tracking-tighter text-neutral-900">Built for complexity. <br class="hidden md:block"/>Designed for clarity.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {features.map((f, i) => (
          <div class={`bg-white rounded-2xl p-8 border shadow-sm hover:shadow-md transition-shadow ${i === 0 ? 'border-brand-200 bg-brand-50/30' : 'border-neutral-200'}`}>
            <div class="text-4xl mb-5">{f.icon}</div>
            <h3 class="text-xl font-black tracking-tight text-neutral-900 mb-3">{f.title}</h3>
            <p class="text-neutral-600 leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  
  <!-- Demo Slideshow -->
  <section id="demo" class="py-24 px-6 bg-neutral-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="section-label mb-3">See It In Action</p>
        <h2 class="text-4xl font-black tracking-tighter text-neutral-900">The ledger your wealth deserves.</h2>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-white/10 aspect-[16/10] mb-16 bg-navy-900" id="demo-reel">

        <div class="demo-slide absolute inset-0" data-slide="0">
          <img src="/screenshots/spreadsheet-chaos.png" alt="Spreadsheet chaos" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">The problem</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">Most wealth maps are fragments.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">Statements, spreadsheets, property deeds, advisor portals — each one a silo. No single source of truth.</p>
          </div>
        </div>
        <div class="demo-slide absolute inset-0 opacity-0" data-slide="1">
          <img loading="lazy" src="/screenshots/entity-management.png" alt="Entity management" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">Multi-entity</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">Every entity, in one vault.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">UK Ltd, personal estate, overseas holding — each with its own jurisdiction, currency, and chart of accounts. Set up in seconds.</p>
          </div>
        </div>
        <div class="demo-slide absolute inset-0 opacity-0" data-slide="2">
          <img loading="lazy" src="/screenshots/universal-vault.png" alt="Universal Vault import" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">Import</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">Drop in a bank statement.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">The categorisation engine reads transaction descriptions and assigns accounts automatically. No manual mapping.</p>
          </div>
        </div>
        <div class="demo-slide absolute inset-0 opacity-0" data-slide="3">
          <img loading="lazy" src="/screenshots/portfolio-analytics.png" alt="Portfolio analytics" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">Illiquid assets</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">Revalue what markets don't price.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">Property, private equity, carried interest — revalue to fair value with IFRS accounting applied automatically.</p>
          </div>
        </div>
        <div class="demo-slide absolute inset-0 opacity-0" data-slide="4">
          <img src="/screenshots/wealth-summary.png" alt="Consolidated wealth summary" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">Consolidated view</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">One number. Every entity.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">Multi-currency equity roll-forward, reconciled across all entities and tax years. Your complete financial picture.</p>
          </div>
        </div>
        <div class="demo-slide absolute inset-0 opacity-0" data-slide="5">
          <img loading="lazy" src="/screenshots/integrity-dashboard.png" alt="Integrity dashboard" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8 md:p-10">
            <p class="text-brand-400 text-xs font-black uppercase tracking-widest mb-2">Trust</p>
            <h3 class="text-white font-black text-xl md:text-2xl tracking-tight leading-snug">Every entry cryptographically chained.</h3>
            <p class="text-white/60 text-sm mt-2 max-w-lg">SHA-256 hash chain — any change to any historical record is immediately detectable. One click to verify your entire history.</p>
          </div>
        </div>
        <div class="absolute bottom-4 right-6 flex items-center gap-2" id="demo-dots">
          <button class="demo-dot w-2 h-2 rounded-full bg-white" data-dot="0"></button>
          <button class="demo-dot w-2 h-2 rounded-full bg-white/40" data-dot="1"></button>
          <button class="demo-dot w-2 h-2 rounded-full bg-white/40" data-dot="2"></button>
          <button class="demo-dot w-2 h-2 rounded-full bg-white/40" data-dot="3"></button>
          <button class="demo-dot w-2 h-2 rounded-full bg-white/40" data-dot="4"></button>
          <button class="demo-dot w-2 h-2 rounded-full bg-white/40" data-dot="5"></button>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 border border-neutral-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-11 h-11 rounded-xl bg-navy-900 flex items-center justify-center mb-6 text-brand-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </div>
          <h3 class="font-black text-neutral-900 text-lg tracking-tight mb-3">Tamper-Evident Records</h3>
          <p class="text-sm text-neutral-500 leading-relaxed">Every journal entry is SHA-256 hash-chained on your device. Any change to any historical record is immediately detectable — a permanent, verifiable audit trail.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-11 h-11 rounded-xl bg-navy-900 flex items-center justify-center mb-6 text-brand-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 010 12.728M15.536 8.464a5 5 0 010 7.072M12 11a1 1 0 100 2 1 1 0 000-2zM3 3l18 18"/></svg>
          </div>
          <h3 class="font-black text-neutral-900 text-lg tracking-tight mb-3">Fully Offline</h3>
          <p class="text-sm text-neutral-500 leading-relaxed">No background network calls — ever. Your vault is an AES-256 encrypted file on your machine. No telemetry, no analytics. WebDAV backups are opt-in and encrypted before leaving the device.</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-neutral-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="w-11 h-11 rounded-xl bg-navy-900 flex items-center justify-center mb-6 text-brand-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="font-black text-neutral-900 text-lg tracking-tight mb-3">Illiquid Asset Revaluations</h3>
          <p class="text-sm text-neutral-500 leading-relaxed">Property, private equity, carried interest, alternatives — revalue to fair value with IFRS accounting applied automatically. Balance sheet and net worth update in real time.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- â"€â"€ How local-first works â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
  <section class="py-20 px-6 bg-navy-900">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="section-label mb-3 text-brand-400">How the privacy model works</p>
        <h2 class="text-3xl font-black tracking-tighter text-white">Your data never leaves your device</h2>
      </div>
