<script is:inline define:vars={{ PRICES }}>
  // â"€â"€ Paddle initialisation â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
  // paddle.js is loaded as an external script and may not be ready when this
  // inline script first runs. _initPaddle() is called eagerly here and again
  // inside openCheckout() so the race condition cannot cause a missed init.
  var _paddleReady = false;

  function _initPaddle() {
    if (_paddleReady) return true;
    if (typeof Paddle === 'undefined') return false;
    try {
      Paddle.Initialize({
        token: 'live_e7f24b9ae86b393f8e32017ffb8',
        eventCallback: function(ev) {
          if (ev.name === 'checkout.error') console.error('[Paddle] checkout.error', ev.data);
        }
      });
      _paddleReady = true;
      return true;
    } catch (err) {
      console.error('[Paddle] Initialize failed:', err);
      return false;
    }
  }

  // Attempt immediate init (succeeds if paddle.js loaded synchronously)
  _initPaddle();

  // ── Resume hosted-checkout transactions ────────────────────────────────────
  // Paddle's hosted payment links redirect to `?_ptxn=txn_...` after capture.
  // Paddle.js auto-detects this when initialized, but the auto-detect is timing-
  // dependent. Explicit handler makes the resume reliable.
  function _resumePaddleTxn() {
    const params = new URLSearchParams(window.location.search);
    const ptxn = params.get('_ptxn');
    if (!ptxn) return;
    if (!_initPaddle()) {
      // Paddle.js not loaded yet — retry shortly.
      setTimeout(_resumePaddleTxn, 250);
      return;
    }
    try {
      Paddle.Checkout.open({ transactionId: ptxn });
    } catch (err) {
      console.error('[Paddle] Failed to resume transaction', err);
    }
  }
  _resumePaddleTxn();

  // â"€â"€ Distribution Logic â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
  const LATEST_API = 'https://aethelgard-licensing.vercel.app/api/latest';

  async function initDistribution() {
    const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
    const cta = document.getElementById('primary-cta');
    const ctaText = document.getElementById('cta-text');
    const macTrigger = document.getElementById('mac-waitlist-trigger');

    if (isMac) {
      ctaText.innerText = 'Mac coming soon — Join Waitlist';
      cta.classList.add('opacity-50', 'pointer-events-none');
      macTrigger.classList.remove('hidden');
    }

    try {
      const response = await fetch(LATEST_API);
      if (!response.ok) throw new Error('API error ' + response.status);
      const data = await response.json();

      if (!isMac) {
        // Update all Windows download buttons on the page
        document.querySelectorAll('#primary-cta, .js-win-download').forEach(el => {
          el.href = data.download_url;
        });
        ctaText.innerText = 'Start Free Trial — Windows';
      }

      const versionTag = document.getElementById('version-tag');
      const versionNumber = document.getElementById('version-number');
      if (versionTag && versionNumber) {
        versionNumber.innerText = data.version;
        versionTag.classList.remove('opacity-0');
      }
    } catch (err) {
      console.warn('Failed to fetch latest version info', err);
      // Button already points at DOWNLOAD_WIN fallback from server-rendered href
    }
  }

  initDistribution();

  // â"€â"€ Pricing Logic â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
  let pricingMode = 'lifetime';

  window.setPricingMode = function setPricingMode(mode) {
    pricingMode = mode;
    const btnLifetime = document.getElementById('btn-lifetime');
    const btnAnnual   = document.getElementById('btn-annual');
    const activeClass = 'px-5 py-2 rounded-lg text-sm font-bold transition-all bg-navy-900 text-white shadow';
    const inactiveClass = 'px-5 py-2 rounded-lg text-sm font-semibold text-neutral-500 transition-all hover:text-neutral-900';
    btnLifetime.className = mode === 'lifetime' ? activeClass : inactiveClass;
    btnAnnual.className   = mode === 'annual'   ? activeClass : inactiveClass;
    ['basic', 'standard', 'advanced'].forEach(tier => {
      document.getElementById('price-' + tier + '-lifetime').classList.toggle('hidden', mode !== 'lifetime');
      document.getElementById('price-' + tier + '-annual').classList.toggle('hidden',   mode !== 'annual');
    });
  }

  window.openAdvisorBundle = function openAdvisorBundle() {
    if (!_initPaddle()) {
      alert('Checkout could not load. Please disable any ad blocker for this site and refresh the page.');
      return;
    }
    try {
      Paddle.Checkout.open({
        items: [{ priceId: PRICES.advisor_bundle, quantity: 1 }],
        settings: { successUrl: 'https://aethelgard.finance/thank-you' },
      });
    } catch (err) {
      console.error('[Paddle] Advisor bundle checkout failed:', err);
      alert('Checkout failed: ' + err.message + '\n\nPlease contact contact@aethelgard.finance');
    }
  }

  window.openCheckout = function openCheckout(tier) {
    if (!_initPaddle()) {
      alert('Checkout could not load. Please disable any ad blocker for this site and refresh the page.');
      return;
    }
    const priceId = PRICES[tier + '_' + pricingMode];
    if (!priceId) {
      console.error('[Paddle] No price ID for tier=' + tier + ' mode=' + pricingMode);
      alert('Checkout configuration error — please contact contact@aethelgard.finance');
      return;
    }
    try {
      Paddle.Checkout.open({
        items: [{ priceId, quantity: 1 }],
        settings: {
          successUrl: 'https://aethelgard.finance/thank-you',
        },
      });
    } catch (err) {
      console.error('[Paddle] Checkout.open failed:', err);
      alert('Checkout failed: ' + err.message + '\n\nPlease try again or contact contact@aethelgard.finance');
    }
  }

  const WAITLIST_API = 'https://aethelgard-licensing.vercel.app/api/waitlist';

  async function submitWaitlist(form, type, successMsg) {
    const email = form.querySelector('input[type="email"]').value;
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Submitting…';
    try {
      const res = await fetch(WAITLIST_API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, type }),
      });
      if (!res.ok) throw new Error('Server error');
      form.outerHTML = '<p class="text-brand-500 font-bold text-lg">' + successMsg.replace('{{email}}', email) + '</p>';
    } catch {
      btn.disabled = false;
      btn.textContent = 'Join waitlist';
      alert('Something went wrong. Please email contact@aethelgard.finance directly.');
    }
  }

  // â"€â"€ Mac Waitlist â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
  const waitlistForm = document.getElementById('mac-waitlist-form');
  if (waitlistForm) {
    waitlistForm.addEventListener('submit', function(e) {
      e.preventDefault();
      submitWaitlist(this, 'mac-waitlist', "You're on the list. We'll email {{email}} the moment Mac is ready.");
    });
  }

  // â"€â"€ Design Partner Form â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
  const designPartnerForm = document.getElementById('design-partner-form');
  if (designPartnerForm) {
    designPartnerForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      const name = this.querySelector('input[name="name"]').value.trim();
      const email = this.querySelector('input[name="email"]').value.trim();
      const role = this.querySelector('input[name="role"]').value.trim();
      const background = this.querySelector('textarea[name="background"]').value.trim();
      const btn = this.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Submitting…';
      try {
        const res = await fetch(WAITLIST_API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, role, background, type: 'design-partner' }),
        });
        if (!res.ok) throw new Error('Server error');
        const firstName = name.split(' ')[0];
        this.outerHTML = '<p class="text-brand-500 font-bold text-lg">Thanks ' + firstName + ' — we\'ll review your application and be in touch at ' + email + ' shortly.</p>';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Request Access';
        alert('Something went wrong. Please email contact@aethelgard.finance directly.');
      }
    });
  }
</script>

<script is:inline>
  (function () {
    var slides = document.querySelectorAll('.demo-slide');
    var dots   = document.querySelectorAll('.demo-dot');
    var current = 0;
    var total   = slides.length;
    var INTERVAL = 7000;
    var FADE     = 700; // ms — matches CSS transition below

    function goTo(n) {
      slides[current].style.opacity = '0';
      dots[current].style.opacity   = '0.4';
      current = (n + total) % total;
      slides[current].style.opacity = '1';
      dots[current].style.opacity   = '1';
    }

    // Apply CSS transition to all slides
    slides.forEach(function (s) {
      s.style.transition = 'opacity ' + (FADE / 1000) + 's ease-in-out';
    });

    // Dot click handlers
    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        clearInterval(timer);
        goTo(parseInt(d.getAttribute('data-dot')));
        timer = setInterval(function () { goTo(current + 1); }, INTERVAL);
      });
    });

    var timer = setInterval(function () { goTo(current + 1); }, INTERVAL);
  })();
</script>

</html>
