<!-- Pricing toggle script -->
<script is:inline>
  function setPricingMode(mode) {
    const isLifetime = mode === 'lifetime';

    // Toggle button styles
    const btnLifetime = document.getElementById('btn-lifetime');
    const btnAnnual   = document.getElementById('btn-annual');
    btnLifetime.className = isLifetime
      ? 'px-5 py-2 rounded-lg text-sm font-bold transition-all bg-navy-900 text-white shadow'
      : 'px-5 py-2 rounded-lg text-sm font-semibold text-neutral-500 transition-all hover:text-neutral-900';
    btnAnnual.className = !isLifetime
      ? 'px-5 py-2 rounded-lg text-sm font-bold transition-all bg-navy-900 text-white shadow'
      : 'px-5 py-2 rounded-lg text-sm font-semibold text-neutral-500 transition-all hover:text-neutral-900';

    // Toggle prices and CTAs for each tier
    ['basic', 'standard', 'advanced'].forEach(tier => {
      const lifetimePrice = document.getElementById(`price-${tier}-lifetime`);
      const annualPrice   = document.getElementById(`price-${tier}-annual`);
      const lifetimeCta   = document.getElementById(`cta-${tier}-lifetime`);
      const annualCta     = document.getElementById(`cta-${tier}-annual`);
      lifetimePrice.classList.toggle('hidden', !isLifetime);
      annualPrice.classList.toggle('hidden',   isLifetime);
      lifetimeCta.classList.toggle('hidden',   !isLifetime);
      annualCta.classList.toggle('hidden',     isLifetime);
    });
  }
</script>

</html>
